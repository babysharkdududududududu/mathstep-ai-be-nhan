# Database Configuration
DATABASE_URL=postgresql://odoo:chithanh1202@localhost:5432/mathstep_db

# JWT Configuration
SECRET_KEY=your-secret-key-change-this-in-production-use-random-string
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=30

# Google OAuth Configuration
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here
GOOGLE_REDIRECT_URI=http://localhost:8000/auth/google/callback

# Email Configuration (Gmail SMTP)
# IMPORTANT: Use Gmail App Password (https://myaccount.google.com/apppasswords), NOT your regular password
# Steps: 1) Enable 2FA, 2) Go to apppasswords, 3) Select Mail + Windows, 4) Copy 16-char password
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password_here
SMTP_FROM=your_email@gmail.com
SMTP_FROM_NAME=MathStep AI

# Server Configuration
DEBUG=False
